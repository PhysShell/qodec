{
  "_comment": "RTK lane. Text transforms run `rtk pipe --filter <name>` (v0.42.4 Unix-pipe mode) over a fixture: log, grep, git-diff, cargo-test. Native command-runners (`rtk rg PATTERN PATH`) proxy ripgrep and stay rtk-command producers with a raw baseline. Every arm is rtk+qodec; pipeline_id distinguishes the modes so scoring never blends them.",
  "cases": [
    {
      "id": "build-log-rtk-log",
      "producer": {"type": "fixture", "path": "corpus/build-log.txt"},
      "transforms": [{"type": "rtk", "filter": "log"}, "qodec"]
    },
    {
      "id": "stacktrace-rtk-log",
      "producer": {"type": "fixture", "path": "corpus/stacktrace.txt"},
      "transforms": [{"type": "rtk", "filter": "log"}, "qodec"]
    },
    {
      "id": "rg-output-rtk-grep",
      "producer": {"type": "fixture", "path": "corpus/rg-output.txt"},
      "transforms": [{"type": "rtk", "filter": "grep"}, "qodec"]
    },
    {
      "id": "git-diff-rtk-gitdiff",
      "producer": {"type": "fixture", "path": "corpus/git-diff.txt"},
      "transforms": [{"type": "rtk", "filter": "git-diff"}, "qodec"]
    },
    {
      "id": "cargo-test-rtk",
      "producer": {"type": "fixture", "path": "evals/interop/fixtures/cargo-test.txt"},
      "transforms": [{"type": "rtk", "filter": "cargo-test"}, "qodec"]
    },
    {
      "id": "rtk-rg-derive-clap",
      "producer": {"type": "rtk-command", "repo": "clap", "argv": ["rg", "-n", "derive", "src"]},
