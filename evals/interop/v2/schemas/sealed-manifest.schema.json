{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "qodec/evals/interop/v2/schemas/sealed-manifest.schema.json",
  "title": "Interop Benchmark v2 — tracked sealed manifest",
  "description": "The ONLY sealed artifact permitted in Git. It describes the sealed bundle without revealing any of its content. Payload, payload paths, gold, question text, content-revealing case ids and tool-output fragments are forbidden and enforced by validate_contract.py.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "bundle_sha256",
    "case_count",
    "question_count",
    "coverage_summary_sha256",
    "created_at",
    "custodian"
  ],
  "properties": {
    "contract_version": { "type": "string", "minLength": 1 },
    "bundle_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "case_count": { "type": "integer", "minimum": 1 },
    "question_count": { "type": "integer", "minimum": 1 },
    "coverage_summary_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "created_at": { "type": "string", "minLength": 1 },
    "custodian": { "type": "string", "minLength": 1 }
  }
}
