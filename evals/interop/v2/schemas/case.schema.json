{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "qodec/evals/interop/v2/schemas/case.schema.json",
  "title": "Interop Benchmark v2 — base case",
  "description": "One base corpus case. Sealed-heldout cases MUST omit payload, payload_path and any content-revealing field in the tracked manifest; only coverage metadata is tracked. Gold and question text never live in a tracked sealed case.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "family",
    "ecosystem",
    "tool",
    "outcome",
    "size_bucket",
    "structure",
    "origin",
    "hazards",
    "split",
    "payload_sha256",
    "question_set_sha256",
    "tokenizer_identity"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Stable unique id. For sealed cases MUST NOT encode payload content."
    },
    "family": {
      "type": "string",
      "enum": [
        "compiler-build",
        "test-runner",
        "lint-static-analysis",
        "search-listing",
        "git-diff-history",
        "exception-stacktrace",
        "application-ci-log",
        "dependency-package",
        "structured-data-query",
        "container-orchestrator",
        "network-api",
        "code-exploration-callgraph"
      ]
    },
    "ecosystem": {
      "type": "string",
      "enum": [
        "dotnet",
        "rust",
        "python",
        "javascript-typescript",
        "go",
        "jvm",
        "language-neutral"
      ]
    },
    "tool": {
      "type": "string",
      "minLength": 1,
      "description": "The concrete tool that produced the primary output (e.g. dotnet-build, cargo-test, ripgrep)."
    },
    "outcome": {
      "type": "string",
      "enum": [
        "success-clean",
        "warning-only",
        "single-failure",
        "multi-failure",
        "mixed-warning-failure",
        "empty-or-no-match",
        "timeout-cancel-truncated-or-malformed"
      ],
      "description": "Exactly one primary outcome per case. Additional shades belong in tags, never in a second outcome."
    },
    "size_bucket": {
      "type": "string",
      "enum": ["tiny", "small", "medium", "large", "xl"],
      "description": "Determined by target-tokenizer token count, not bytes. tiny <256, small 256-1023, medium 1024-4095, large 4096-16383, xl >=16384."
    },
    "structure": {
      "type": "string",
      "minLength": 1,
      "description": "Shape of the payload, e.g. flat-log, sectioned-report, tree, table, json, diff."
    },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "source_description",
        "sanitization",
        "source_sha256",
        "generator_version"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["real", "synthetic", "metamorphic"]
        },
        "source_description": {
          "type": "string",
          "minLength": 1
        },
        "sanitization": {
          "type": "string",
          "minLength": 1,
          "description": "How the capture was sanitized. Secrets must be synthetic or irreversibly sanitized; use 'none' only when nothing sensitive existed."
        },
        "source_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "generator_version": {
          "type": "string",
          "minLength": 1,
          "description": "Version of the capture or synthesis generator. For real captures use the capture-tool version."
        }
      }
    },
    "hazards": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "duplicate-basename",
          "windows-path",
          "posix-path",
          "spaces-or-quotes-in-path",
          "unicode",
          "combining-characters",
          "ansi",
          "carriage-return-progress",
          "crlf",
          "long-identifiers",
          "hostile-qodec-markers",
          "alias-like-glyphs",
          "nested-repetition",
          "conflicting-old-and-new-facts",
          "sanitized-secret-like-values",
          "empty-result",
          "truncated-output",
          "binary-file-notice",
          "generated-or-minified-content"
        ]
      }
    },
    "tags": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 },
      "description": "Free secondary properties, e.g. 'adversarial', 'primary', 'high-savings'. The single primary family lives in `family`; do NOT invent a 'misc' family."
    },
    "split": {
      "type": "string",
      "enum": ["public-development", "public-validation", "sealed-heldout"]
    },
    "payload_path": {
      "type": "string",
      "minLength": 1,
      "description": "Only permitted for public cases. MUST be absent for sealed-heldout cases."
    },
    "payload_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "question_set_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "tokenizer_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "sha256"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
