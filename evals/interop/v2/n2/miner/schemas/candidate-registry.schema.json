{
  "type": "object",
  "required": ["registry_version", "candidates"],
  "additionalProperties": true,
  "properties": {
    "registry_version": { "type": "string", "minLength": 1 },
    "candidates": {
      "type": "array",
      "items": { "$ref": "#/definitions/candidate" }
    }
  },
  "definitions": {
    "candidate": {
      "type": "object",
      "required": [
        "candidate_id",
        "repository",
        "commit_sha",
        "ecosystem",
        "expected_log_family",
        "origin_kind",
        "license",
        "project",
        "toolchain_request",
        "dependency_lock",
        "network_requirements",
        "submodule_status",
        "git_lfs_status",
        "private_feed_status",
        "external_service_requirements",
        "container_requirements",
        "estimated_resource_class",
        "expected_capture_command_class",
        "security_flags",
        "reproducibility_class",
        "selection_status",
        "evidence_references",
        "status_history"
      ],
      "additionalProperties": true,
      "properties": {
        "candidate_id": { "type": "string", "minLength": 1 },
        "repository": {
          "type": "object",
          "required": ["url", "owner", "name"],
          "additionalProperties": true,
          "properties": {
            "url": { "type": "string", "pattern": "^https://github\\.com/" },
            "owner": { "type": "string", "minLength": 1 },
            "name": { "type": "string", "minLength": 1 }
          }
        },
        "commit_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "tree_sha": { "type": ["string", "null"] },
        "ecosystem": {
          "type": "string",
          "enum": ["dotnet", "rust", "python", "jvm-maven", "jvm-gradle"]
        },
        "expected_log_family": { "type": "string", "minLength": 1 },
        "origin_kind": {
          "type": "string",
          "enum": ["public-third-party", "synthetic-first-party", "n2a-reference-only"]
        },
        "license": {
          "type": "object",
          "required": ["status", "spdx", "file"],
          "additionalProperties": true,
          "properties": {
            "status": { "type": "string", "enum": ["clear", "missing", "ambiguous"] },
            "spdx": { "type": ["string", "null"] },
            "file": { "type": ["string", "null"] }
          }
        },
        "project": {
          "type": "object",
          "required": ["entry_point"],
          "additionalProperties": true,
          "properties": {
            "entry_point": { "type": ["string", "null"] },
            "ambiguous": { "type": "boolean" }
          }
        },
        "toolchain_request": {
          "type": "object",
          "required": ["requested_version_or_range", "resolver_mechanism"],
          "additionalProperties": true,
          "properties": {
            "requested_version_or_range": { "type": "string", "minLength": 1 },
            "resolver_mechanism": { "type": "string", "minLength": 1 }
          }
        },
        "dependency_lock": {
          "type": "object",
          "required": ["present", "files"],
          "additionalProperties": true,
          "properties": {
            "present": { "type": "boolean" },
            "files": { "type": "array", "items": { "type": "string" } }
          }
        },
        "network_requirements": {
          "type": "object",
          "required": ["required_during_untrusted_execution"],
          "additionalProperties": true,
          "properties": {
            "required_during_untrusted_execution": { "type": "boolean" },
            "notes": { "type": "string" }
          }
        },
        "submodule_status": { "type": "string", "enum": ["none", "present"] },
        "git_lfs_status": { "type": "string", "enum": ["none", "present"] },
        "private_feed_status": { "type": "string", "enum": ["none", "required"] },
        "external_service_requirements": { "type": "array", "items": { "type": "string" } },
        "container_requirements": { "type": "array", "items": { "type": "string" } },
        "estimated_resource_class": { "type": "string", "enum": ["small", "medium", "large"] },
        "expected_capture_command_class": { "type": "string", "minLength": 1 },
        "security_flags": { "type": "array", "items": { "type": "string" } },
        "reproducibility_class": {
          "type": "string",
          "enum": ["expected-byte-reproducible", "expected-semantically-reproducible", "unknown"]
        },
        "selection_status": {
          "type": "string",
          "enum": ["discovered", "inspected", "ineligible", "eligible", "selected", "frozen", "rejected-after-selection"]
        },
        "rejection_reason": { "type": ["string", "null"] },
        "evidence_references": { "type": "array", "items": { "type": "string" } },
        "status_history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["status", "registry_version"],
            "additionalProperties": true,
            "properties": {
              "status": { "type": "string" },
              "registry_version": { "type": "string" },
              "reason": { "type": ["string", "null"] },
              "override": { "type": ["object", "null"] }
            }
          }
        }
      }
    }
  }
}
