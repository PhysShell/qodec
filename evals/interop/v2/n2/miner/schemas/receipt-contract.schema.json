{
  "type": "object",
  "required": [
    "receipt_contract_version",
    "source_identity",
    "license_identity",
    "acquisition_identity",
    "adapter_identity",
    "toolchain_requested",
    "toolchain_resolved",
    "toolchain_executed",
    "sandbox_identity",
    "outer_isolation",
    "resource_limits",
    "command_argv",
    "environment_variable_names",
    "stdout_identity",
    "stderr_identity",
    "termination",
    "sanitization",
    "reproducibility"
  ],
  "additionalProperties": true,
  "properties": {
    "receipt_contract_version": { "type": "string", "enum": ["n2b-receipt-contract-v1"] },
    "source_identity": {
      "type": "object",
      "required": ["commit_sha", "archive_sha256"],
      "properties": {
        "commit_sha": { "type": "string", "minLength": 1 },
        "archive_sha256": { "type": "string", "minLength": 1 }
      }
    },
    "license_identity": {
      "type": "object",
      "required": ["sha256"],
      "properties": {
        "spdx": { "type": ["string", "null"] },
        "sha256": { "type": "string", "minLength": 1 }
      }
    },
    "acquisition_identity": {
      "type": "object",
      "required": ["checkout_action_identity", "persist_credentials"],
      "properties": {
        "checkout_action_identity": { "type": "string", "minLength": 1 },
        "persist_credentials": { "type": "boolean", "enum": [false] }
      }
    },
    "adapter_identity": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "toolchain_requested": {
      "type": "object",
      "required": ["version_or_range", "resolver_mechanism"],
      "properties": {
        "version_or_range": { "type": "string", "minLength": 1 },
        "resolver_mechanism": { "type": "string", "minLength": 1 }
      }
    },
    "toolchain_resolved": {
      "type": "object",
      "required": ["resolved_version", "runtime_identifier", "resolved_executable_path"],
      "properties": {
        "resolved_version": { "type": "string", "minLength": 1 },
        "runtime_identifier": { "type": "string", "minLength": 1 },
        "resolved_executable_path": { "type": "string", "minLength": 1 }
      }
    },
    "toolchain_executed": {
      "type": "object",
      "required": ["executed_argv0", "executed_binary_absolute_path", "executed_binary_sha256", "classification"],
      "properties": {
        "executed_argv0": { "type": "string", "minLength": 1 },
        "executed_binary_absolute_path": { "type": "string", "minLength": 1 },
        "executed_binary_sha256": { "type": "string", "minLength": 1 },
        "classification": {
          "type": "string",
          "enum": ["exact-match", "compatible-resolution", "unexpected-resolution", "identity-missing"]
        }
      }
    },
    "sandbox_identity": {
      "type": "object",
      "required": ["sandboy_commit_sha", "policy_sha256"],
      "properties": {
        "sandboy_commit_sha": { "type": "string", "minLength": 1 },
        "policy_sha256": { "type": "string", "minLength": 1 }
      }
    },
    "outer_isolation": {
      "type": "object",
      "required": ["network_isolation", "wall_clock_timeout_s"],
      "properties": {
        "network_isolation": { "type": "boolean", "enum": [true] },
        "wall_clock_timeout_s": { "type": "number", "minimum": 0.000001 }
      }
    },
    "resource_limits": {
      "type": "object",
      "required": ["cpu_time_limit_s", "process_count_limit", "memory_enforcement_mechanism"],
      "properties": {
        "cpu_time_limit_s": { "type": "number", "minimum": 0.000001 },
        "process_count_limit": { "type": "integer", "minimum": 1 },
        "memory_enforcement_mechanism": {
          "type": "string",
          "enum": ["cgroup-enforced", "outer-runner-enforced", "unavailable"]
        }
      }
    },
    "command_argv": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "environment_variable_names": {
      "type": "array",
      "items": { "type": "string" }
    },
    "stdout_identity": {
      "type": "object",
      "required": ["sha256"],
      "properties": { "sha256": { "type": "string", "minLength": 1 } }
    },
    "stderr_identity": {
      "type": "object",
      "required": ["sha256"],
      "properties": { "sha256": { "type": "string", "minLength": 1 } }
    },
    "termination": {
      "type": "object",
      "required": ["exit_code"],
      "properties": { "exit_code": { "type": "integer" } }
    },
    "sanitization": {
      "type": "object",
      "required": ["profile_version", "transformations"],
      "properties": {
        "profile_version": { "type": "string", "minLength": 1 },
        "transformations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "reproducibility": {
      "type": "object",
      "required": ["class"],
      "properties": {
        "class": {
          "type": "string",
          "enum": ["expected-byte-reproducible", "expected-semantically-reproducible", "unknown"]
        }
      }
    }
  }
}
