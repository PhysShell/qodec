{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "corpus/schemas/snapshot-manifest.schema.json",
  "title": "Snapshot manifest",
  "description": "Pins every byte-artifact of a case bundle by SHA256. All referenced paths are relative and must stay inside the case bundle (no '..', absolute paths, or symlink escape).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "snapshot_version",
    "raw_stdout_sha256",
    "raw_stderr_sha256",
    "rtk_stdout_sha256",
    "rtk_stderr_sha256",
    "native_receipt_sha256",
    "rtk_receipt_sha256",
    "fixture_tree_sha256",
    "capture_recipe_sha256",
    "provenance_sha256",
    "evidence_map_sha256"
  ],
  "properties": {
    "case_id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "snapshot_version": { "type": "string", "minLength": 1 },
    "raw_stdout_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "raw_stderr_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "rtk_stdout_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "rtk_stderr_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "native_receipt_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "rtk_receipt_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "fixture_tree_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "capture_recipe_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "provenance_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "evidence_map_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
