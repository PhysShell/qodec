{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "corpus/schemas/evidence-map.schema.json",
  "title": "Evidence map (structured ground truth)",
  "description": "Structured ground truth grounded in raw/RTK snapshot streams. This is NOT a reader-question schema. Evidence spans must reference existing lines within a declared stream and may never reference qodec-derived output.",
  "type": "object",
  "additionalProperties": false,
  "required": ["case_id", "facts"],
  "properties": {
    "case_id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "facts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/fact" }
    }
  },
  "definitions": {
    "fact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fact_id", "kind", "stream", "evidence"],
      "properties": {
        "fact_id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "kind": {
          "type": "string",
          "enum": ["entity", "exact", "count", "set", "relation", "ordering", "absence", "decision-fact"]
        },
        "stream": {
          "type": "string",
          "enum": ["raw.stdout", "raw.stderr", "rtk.stdout", "rtk.stderr"]
        },
        "value": {},
        "description": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["start_line", "end_line"],
            "properties": {
              "start_line": { "type": "integer", "minimum": 1 },
              "end_line": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    }
  }
}
