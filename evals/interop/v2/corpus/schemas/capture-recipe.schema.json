{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "corpus/schemas/capture-recipe.schema.json",
  "title": "Capture recipe",
  "description": "How a case's raw and RTK snapshots are produced. Commands are argv ARRAYS only — never shell strings. Shell execution (shell:true, bash -c, sh -c, cmd /c, powershell -Command, pipes) is forbidden in this contract version; a future version may add an explicit shell policy.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "native",
    "rtk",
    "environment_allowlist",
    "expected_exit_code_class",
    "timeout_s",
    "network_policy",
    "locale",
    "timezone",
    "source_date_epoch"
  ],
  "properties": {
    "setup": {
      "type": "array",
      "items": { "$ref": "#/definitions/step" }
    },
    "native": { "$ref": "#/definitions/step" },
    "rtk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["argv"],
      "properties": {
        "argv": { "$ref": "#/definitions/argv" }
      }
    },
    "environment_allowlist": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
      "uniqueItems": true
    },
    "expected_exit_code_class": {
      "type": "string",
      "enum": ["zero", "nonzero", "exact", "any"]
    },
    "expected_exit_code": { "type": "integer" },
    "timeout_s": { "type": "number", "minimum": 1 },
    "network_policy": { "type": "string", "enum": ["disabled", "allowlist"] },
    "locale": { "type": "string", "minLength": 1 },
    "timezone": { "type": "string", "minLength": 1 },
    "source_date_epoch": { "type": "integer", "minimum": 0 }
  },
  "definitions": {
    "argv": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["argv"],
      "properties": {
        "argv": { "$ref": "#/definitions/argv" },
        "cwd": { "type": "string" },
        "stdin_path": { "type": ["string", "null"] }
      }
    }
  }
}
