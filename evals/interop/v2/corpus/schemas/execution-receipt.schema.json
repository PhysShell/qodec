{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "corpus/schemas/execution-receipt.schema.json",
  "title": "Execution receipt",
  "description": "One recorded execution (setup / native / rtk). capture_timestamp is metadata and must never enter snapshot bytes. Identity fields may be null when not run under Nix; they must still be present.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_version",
    "case_id",
    "phase",
    "argv",
    "cwd",
    "environment_allowlist",
    "stdin_sha256",
    "stdout_sha256",
    "stderr_sha256",
    "exit_code",
    "wall_time_s",
    "timeout_status",
    "locale",
    "timezone",
    "nix_system",
    "nix_version",
    "nixpkgs_revision",
    "flake_lock_sha256",
    "repository_head_sha",
    "checked_out_commit_sha",
    "qodec_tree_sha",
    "tool_identity",
    "tool_binary_sha256",
    "capture_timestamp"
  ],
  "properties": {
    "receipt_version": { "type": "string", "minLength": 1 },
    "case_id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "phase": { "type": "string", "enum": ["setup", "native", "rtk"] },
    "argv": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "cwd": { "type": "string" },
    "environment_allowlist": { "type": "array", "items": { "type": "string" } },
    "stdin_sha256": { "type": ["string", "null"] },
    "stdout_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "stderr_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "exit_code": { "type": "integer" },
    "wall_time_s": { "type": "number" },
    "timeout_status": { "type": "string", "enum": ["ok", "timed-out"] },
    "locale": { "type": "string" },
    "timezone": { "type": "string" },
    "nix_system": {},
    "nix_version": {},
    "nixpkgs_revision": {},
    "flake_lock_sha256": {},
    "repository_head_sha": {},
    "checked_out_commit_sha": {},
    "qodec_tree_sha": {},
    "tool_identity": { "type": "string", "minLength": 1 },
    "tool_binary_sha256": {},
    "capture_timestamp": {},
    "rtk_source_sha": {},
    "rtk_argv": { "type": "array", "items": { "type": "string" } },
    "rtk_classification": {
      "type": "string",
      "enum": ["reduced", "passthrough-never-worse", "explicit-passthrough", "unsupported", "failed"]
    },
    "payload_changed": { "type": "boolean" },
    "never_worse_returned_raw": { "type": "boolean" }
  }
}
