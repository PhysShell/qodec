{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scope", "contract_version", "status", "split_policy", "case_count",
    "cases", "min_families", "min_ecosystems", "distribution",
    "source_policy", "deviation_justification", "non_gating"
  ],
  "properties": {
    "scope": { "type": "string", "enum": ["N1"] },
    "contract_version": { "type": "string" },
    "status": { "type": "string" },
    "split_policy": { "type": "string", "enum": ["public-development-only"] },
    "case_count": { "type": "integer", "minimum": 10 },
    "cases": {
      "type": "array",
      "minItems": 10,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9-]+$" }
    },
    "min_families": { "type": "integer", "minimum": 4 },
    "min_ecosystems": { "type": "integer", "minimum": 3 },
    "distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["families", "ecosystems"],
      "properties": {
        "families": { "type": "object" },
        "ecosystems": { "type": "object" }
      }
    },
    "source_policy": { "type": "string" },
    "deviation_justification": { "type": "string" },
    "interop_findings": { "type": "string" },
    "non_gating": { "type": "boolean", "enum": [true] }
  }
}
