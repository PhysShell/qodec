{
  "type": "object",
  "additionalProperties": false,
  "required": ["case_id", "primary_stream", "anchors"],
  "properties": {
    "case_id": { "type": "string" },
    "primary_stream": { "type": "string", "enum": ["raw.stdout", "raw.stderr"] },
    "anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["anchor_id", "kind", "value", "stream"],
        "properties": {
          "anchor_id": { "type": "string", "minLength": 1 },
          "kind": {
            "type": "string",
            "enum": ["exact", "entity", "error-code", "source-location",
                     "summary-count", "diagnostic-message"]
          },
          "value": { "type": "string", "minLength": 1 },
          "stream": {
            "type": "string",
            "enum": ["raw.stdout", "raw.stderr", "rtk.stdout", "rtk.stderr"]
          }
        }
      }
    }
  }
}
