{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id", "split", "family", "ecosystem", "tool", "primary_stream",
    "origin_kind", "capture_mode", "rtk_mode", "snapshot_policy", "outcome",
    "hand_authored", "provenance_path", "capture_recipe_path", "anchors_path",
    "snapshot_manifest_path", "markers", "tags", "notes"
  ],
  "properties": {
    "case_id": { "type": "string", "pattern": "^[a-z0-9-]+$", "minLength": 3 },
    "split": { "type": "string", "enum": ["public-development"] },
    "family": {
      "type": "string",
      "enum": [
        "compiler-build", "test-runner", "lint-static-analysis", "search-listing",
        "git-diff-history", "exception-stacktrace", "application-ci-log",
        "dependency-package", "structured-data-query", "container-orchestrator",
        "network-api", "code-exploration-callgraph"
      ]
    },
    "ecosystem": { "type": "string", "minLength": 2 },
    "tool": { "type": "string", "minLength": 2 },
    "primary_stream": { "type": "string", "enum": ["raw.stdout", "raw.stderr"] },
    "origin_kind": {
      "type": "string",
      "enum": ["generated-first-party", "upstream-fixture", "external-dataset-slice"]
    },
    "capture_mode": { "type": "string", "enum": ["reproducible-command"] },
    "rtk_mode": { "type": "string", "enum": ["pipe-filter", "pipe-auto", "explicit-passthrough"] },
    "rtk_filter": { "type": ["string", "null"] },
    "snapshot_policy": { "type": "string", "enum": ["raw-and-rtk"] },
    "outcome": {
      "type": "string",
      "enum": [
        "success-clean", "warning-only", "single-failure", "multi-failure",
        "mixed-warning-failure", "empty-or-no-match",
        "timeout-cancel-truncated-or-malformed"
      ]
    },
    "hand_authored": { "type": "boolean" },
    "provenance_path": { "type": "string" },
    "capture_recipe_path": { "type": "string" },
    "anchors_path": { "type": "string" },
    "snapshot_manifest_path": { "type": "string" },
    "markers": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" }
  }
}
